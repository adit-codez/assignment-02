
CREATE DATABASE IF NOT EXISTS product_catalog;
USE product_catalog;

DROP TABLE IF EXISTS products;
CREATE TABLE products (
    product_id      VARCHAR(10)     NOT NULL,
    product_name    VARCHAR(100)    NOT NULL,
    brand           VARCHAR(100)    NOT NULL,
    category        VARCHAR(50)     NOT NULL,
    price           DECIMAL(10, 2)  NOT NULL,
    stock           INT             NOT NULL DEFAULT 0,
    rating          DECIMAL(3, 1),
    total_reviews   INT             DEFAULT 0,
    added_on        DATE            NOT NULL,
    CONSTRAINT pk_products PRIMARY KEY (product_id)
);

-- ============================================================
-- TABLE: electronics_details
-- ============================================================
DROP TABLE IF EXISTS electronics_details;
CREATE TABLE electronics_details (
    product_id          VARCHAR(10)     NOT NULL,
    screen_size_inches  DECIMAL(4, 1),
    battery_mah         INT,
    voltage             VARCHAR(20),
    warranty_years      INT             NOT NULL DEFAULT 1,
    connectivity        VARCHAR(255),   -- comma-separated: Wi-Fi, Bluetooth, USB
    operating_system    VARCHAR(50),
    processor           VARCHAR(100),
    ram_gb              INT,
    storage_gb          INT,
    CONSTRAINT pk_electronics PRIMARY KEY (product_id),
    CONSTRAINT fk_electronics_product FOREIGN KEY (product_id)
        REFERENCES products(product_id) ON DELETE CASCADE
);

-- ============================================================
-- TABLE: clothing_details
-- ============================================================
DROP TABLE IF EXISTS clothing_details;
CREATE TABLE clothing_details (
    product_id          VARCHAR(10)     NOT NULL,
    fabric              VARCHAR(100)    NOT NULL,
    fit_type            VARCHAR(50),
    sleeve_type         VARCHAR(50),
    available_sizes     VARCHAR(100),   -- comma-separated: S, M, L, XL
    available_colors    VARCHAR(200),   -- comma-separated
    care_instructions   VARCHAR(255),
    gender              VARCHAR(20),
    occasion            VARCHAR(100),
    CONSTRAINT pk_clothing PRIMARY KEY (product_id),
    CONSTRAINT fk_clothing_product FOREIGN KEY (product_id)
        REFERENCES products(product_id) ON DELETE CASCADE
);

-- ============================================================
-- TABLE: grocery_details
-- ============================================================
DROP TABLE IF EXISTS grocery_details;
CREATE TABLE grocery_details (
    product_id          VARCHAR(10)     NOT NULL,
    weight_kg           DECIMAL(5, 2),
    ingredients         VARCHAR(255),
    calories_per_100g   INT,
    protein_g           DECIMAL(5, 2),
    carbohydrates_g     DECIMAL(5, 2),
    fat_g               DECIMAL(5, 2),
    fiber_g             DECIMAL(5, 2),
    allergens           VARCHAR(200),
    certifications      VARCHAR(200),
    storage_instructions VARCHAR(255),
    manufactured_date   DATE,
    expiry_date         DATE            NOT NULL,
    CONSTRAINT pk_grocery PRIMARY KEY (product_id),
    CONSTRAINT fk_grocery_product FOREIGN KEY (product_id)
        REFERENCES products(product_id) ON DELETE CASCADE
);

